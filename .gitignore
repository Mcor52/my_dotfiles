# Package manager folders (if you happen to have them)
node_modules/
.venv/

# Secret/Private files (even if you don't have them yet, good for safety)
*.key
*.pem
.env
secrets.zsh

# System/Editor junk
.DS_Store
*.swp
.netrwhist

# Ignore Spicetify junk
spicetify_customapps/**/cache/
spicetify_customapps/**/_state/
